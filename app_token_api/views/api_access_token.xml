<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree (List) View -->
    <record id="view_api_access_token_tree" model="ir.ui.view">
        <field name="name">partner.api.key.tree</field>
        <field name="model">partner.api.key</field>
        <field name="arch" type="xml">
            <list string="Partner API Keys">
                <field name="user_id"/>
                <field name="api_key"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_api_access_token_form" model="ir.ui.view">
        <field name="name">partner.api.key.form</field>
        <field name="model">partner.api.key</field>
        <field name="arch" type="xml">
            <form string="Partner API Key">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="api_key" readonly="1"/>
                        <field name="expiry_date" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Code to show device_token field in users form -->
    <record id="view_users_form_inherit_device_token" model="ir.ui.view">
        <field name="name">res.users.form.inherit.device.token</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Add inside Preferences tab -->
            <xpath expr="//page[@name='preferences']//field[@name='action_id']" position="after">
                <field name="device_token"/>
            </xpath>

        </field>
    </record>

    <!-- Action -->
    <record id="action_api_access_token" model="ir.actions.act_window">
        <field name="name">Partner API Keys</field>
        <field name="res_model">partner.api.key</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Add to Menu -->
    <menuitem id="menu_partner_api_root" name="App API" sequence="10" groups="base.group_system"/>

    <menuitem id="menu_partner_api_key" name="API Keys" parent="menu_partner_api_root" action="action_api_access_token" sequence="10"/>
</odoo>
