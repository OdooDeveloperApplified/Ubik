<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mr_doctor_avg_sales_report_tree" model="ir.ui.view">
        <field name="name">mr.doctor.avg.sales.report.tree</field>
        <field name="model">mr.doctor.avg.sales.report</field>
        <field name="arch" type="xml">
            <list string="Doctor Avg Sales (FY Comparison)" 
                  create="0" 
                  limit="200"
                  default_order="curr_total desc">
                <field name="territory_id"/>
                <field name="doc_unique_id"/>
                <field name="doctor_id"/>
                <field name="fiscal_year" optional="1"/>

                <field name="prev_total" sum="Total" optional="1"/>
                <field name="curr_total" sum="Total"/>
                
                <field name="prev_avg" sum="Avg" optional="1"/>
                <field name="curr_avg" sum="Avg"/>
                
                <field name="total_diff" optional="1"/>
                <field name="avg_diff" optional="1"/>
                <field name="pct_change" widget="percentage" optional="1"/>
            </list>
        </field>
    </record>

    <record id="view_yearwise_sales_search" model="ir.ui.view">
        <field name="name">yearwise.sales.search</field>
        <field name="model">mr.doctor.avg.sales.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="territory_id"/>
                <field name="doctor_id"/>
                <field name="doc_unique_id"/>
                <field name="fiscal_year"/>
                
                <filter string="Current Year"
                    name="current_year"
                    domain="[('is_current_fy', '=', True)]"/>
                
                <filter string="Positive Growth"
                    name="positive_growth"
                    domain="[('pct_change', '&gt;', 0)]"/>
                    
                <filter string="Negative Growth"
                    name="negative_growth"
                    domain="[('pct_change', '&lt;', 0)]"/>
                    
                <separator/>
                <filter string="Territory" 
                    name="group_territory"
                    context="{'group_by': 'territory_id'}"/>
                <filter string="Fiscal Year" 
                    name="group_fiscal_year"
                    context="{'group_by': 'fiscal_year'}"/>
            </search>
        </field>
    </record>

    <record id="action_mr_doctor_avg_sales_report" model="ir.actions.act_window">
        <field name="name">Difference with percentage(%)</field>
        <field name="res_model">mr.doctor.avg.sales.report</field>
        <field name="view_mode">list</field>
        <field name="limit">200</field>
        <field name="context">
            {
                'search_default_current_year': 1,
                'default_order': 'curr_total desc'
            }
        </field>
    </record>

    <menuitem id="menu_mr_doctor_avg_sales_report"
          name="Yearly Avg Sales"
          parent="ubik_app.menu_report_doctor"
          action="action_mr_doctor_avg_sales_report" 
          sequence="30"/>

</odoo>