<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Territory Name Form View -->
    <record id="view_territory_name_form" model="ir.ui.view">
        <field name="name">territory.name.form</field>
        <field name="model">territory.name</field>
        <field name="arch" type="xml">
            <form string="Territory Name">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>

                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Territory Name Tree View -->
    <record id="view_territory_name_tree" model="ir.ui.view">
        <field name="name">territory.name.tree</field>
        <field name="model">territory.name</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    
    <!-- Territory Name Action -->
    <record id="action_territory_name" model="ir.actions.act_window">
        <field name="name">Territory Name</field>
        <field name="res_model">territory.name</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create and manage Territory Names.
            </p>
        </field>
    </record>

    <!-- Master Menu under Product > Configuration -->
    <menuitem id="menu_territory_master_root"
              name="Master"
              parent="contacts.res_partner_menu_config"
              
              />

    <!-- Category Menu under Contacts > Configuration > Master -->
    <menuitem id="menu_territory_name"
              name="Territory Name"
              parent="ubik_contact.menu_territory_master_root"
              action="action_territory_name"
              sequence="1"
              />

</odoo>